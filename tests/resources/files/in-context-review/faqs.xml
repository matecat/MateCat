			<segment state="initial">
				<source>How does WKND pay for itself?</source>
				<target>¿Cómo se amortiza WKND?</target>
			</segment>
		</unit>
		<unit id="8" matecat:resname="data-node-path=/content/wknd/language-masters/es-es/faqs/jcr:content/root/container/container/accordion/item_1/text" matecat:restype="x-attribute_name_value" matecat:x-is-multi-value="false" matecat:x-node-path="/content/wknd/language-masters/es-es/faqs/jcr:content/root/container/container/accordion/item_1/text" matecat:x-property-name="text" matecat:x-restype="x-jcr-html" name="/content/wknd/language-masters/es-es/faqs/jcr:content/root/container/container/accordion/item_1/text/text" matecat:segment-id="42859704">
			<mda:metadata>
				<mda:metaGroup id="word_count_tu.8.0" category="row_xml_attribute">
					<mda:meta type="x-matecat-raw">34</mda:meta>
					<mda:meta type="x-matecat-weighted">28.9</mda:meta>
				</mda:metaGroup>
			</mda:metadata>
			<segment state="initial">
				<source>&lt;p&gt;WKND charges a small fee for local promoters that want to sponsor their adventures and events on the WKND site.&amp;nbsp; Sponsored Adventures may get sorted to more prominent positions in our Adventures listings pages.&lt;/p&gt;
&lt;h3&gt;&amp;nbsp;&lt;/h3&gt;
</source>
				<target>&lt;p&gt;WKND cobra una pequeña tarifa a los promotores locales que quieran patrocinar sus aventuras y eventos en el sitio de WKND. &amp;nbsp;Las aventuras patrocinadas pueden clasificarse en posiciones más destacadas en nuestras páginas de anuncios de aventuras.&#10;&lt;/p&gt;&lt;h3&gt;&amp;nbsp;&#10;&lt;/h3&gt;</target>
			</segment>
		</unit>
